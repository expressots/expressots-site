{
  "name": "expressots-site",
  "version": "0.1.0",
  "homepage": "https://www.expresso-ts.com",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "cross-env NODE_ENV=production next build",
    "build:v2": "next build",
    "export": "next export",
    "prod": "npx serve@latest out",
    "start": "next start",
    "lint": "next lint --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "next lint --fix --cache --cache-location node_modules/.cache/eslint/",
    "format": "prettier --write . --cache",
    "prepare": "husky"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stackblitz/sdk": "^1.11.0",
    "@tabler/icons-react": "^3.44.0",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@uidotdev/usehooks": "^2.4.0",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "next": "^15.5.18",
    "postcss": "^8.5.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "scrollen": "^0.0.2",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "^8.5.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.18",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --cache --cache-location node_modules/.cache/eslint/ --fix",
      "prettier --write --cache"
    ],
    "*.{json,md,mdx,css,scss}": [
      "prettier --write --cache"
    ]
  }
}
